# ============================================================
# CONFIGURACIÓN DEL BOT DE TELEGRAM - SISTEMA DE GAMIFICACIÓN
# ============================================================
# Copia este archivo como .env y completa los valores

# Token del bot (obtenido desde @BotFather en Telegram)
BOT_TOKEN=TU_TOKEN_AQUI

# ID del grupo/canal de Telegram donde se envían las tareas
# Para obtenerlo: añade @userinfobot al grupo y escribe /start
GROUP_CHAT_ID=-100XXXXXXXXXX

# IDs de Telegram de los administradores (separados por coma)
# Para obtener tu ID: escribe /start a @userinfobot
ADMIN_IDS=123456789,987654321

# API Key de Anthropic (Claude) para validar screenshots
# Obtener en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-XXXXXXXX

# Nombre del proyecto (aparece en comprobantes y mensajes)
PROJECT_NAME=Entre Montañas

# Zona horaria para el scheduler
TIMEZONE=America/Bogota
